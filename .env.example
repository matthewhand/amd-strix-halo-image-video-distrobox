# Copy to .env and uncomment to override default paths.
# All paths default to project-local ./folders if not set.
# .env is gitignored so local-machine specifics never leak into the repo.

# Point to your existing HuggingFace cache (avoids re-downloading models)
#HF_CACHE=~/.cache/huggingface

# Model and output directories
#QWEN_OUTPUTS=~/.qwen-image-studio
#WAN_MODELS=./wan-models
#COMFY_MODELS=./comfy-models
#COMFY_OUTPUTS=./comfy-outputs
#COMFY_INPUT=./comfy-input

# Optional: point at a large external SSD if your root filesystem is tight.
# Examples (adjust to your machine — these are user-specific paths, hence
# kept out of the repo):
#COMFY_OUTPUTS=/mnt/data/slop/comfy-outputs
#HF_CACHE=/mnt/downloads/huggingface-cache

# TTS worker (scripts/qwen_tts_serve.py).
# Leave unset to auto-pick first writable of:
#   /workspace/tts → ~/.slopfinity/tts → /tmp/slopfinity-tts
#TTS_OUT_DIR=~/.slopfinity/tts

# Overlay scripts (scripts/ai_slop_overlay.py, scripts/mux_smoke.py)
# Font path for the AI-slop overlay captions
#SLOP_OVERLAY_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
# Smoke-test inputs/outputs for scripts/mux_smoke.py
#MUX_SMOKE_VIDEO=./comfy-outputs/canary_hero_00001_.mp4
#MUX_SMOKE_OUT_REPLACE=./comfy-outputs/canary_hero_replaced.mp4
#MUX_SMOKE_OUT_MIX=./comfy-outputs/canary_hero_mixed.mp4

# ─── Branding aesthetics ──────────────────────────────────────────────────
# Page-level background / wallpaper. Each var overrides the active branding
# profile's `aesthetics.<field>`. Leave unset to use the profile default.
# Setting SLOPFINITY_BG_IMAGE OR SLOPFINITY_BG_SVG enables the layer.
#
# Image URL (raster, SVG file, or data:URI):
#SLOPFINITY_BG_IMAGE=/static/icons/icon-512.png
#SLOPFINITY_BG_IMAGE=https://example.com/wallpaper.jpg
#SLOPFINITY_BG_IMAGE=data:image/png;base64,iVBORw0KGgoAAAA...
#
# Or inline SVG (overrides image URL when both are set):
#SLOPFINITY_BG_SVG=<svg xmlns='http://www.w3.org/2000/svg' width='40' height='40'><circle cx='20' cy='20' r='3' fill='%23ff79c6'/></svg>
#
# Layout knobs:
#SLOPFINITY_BG_REPEAT=repeat            # repeat | repeat-x | repeat-y | no-repeat | space | round
#SLOPFINITY_BG_SIZE=cover               # cover | contain | <CSS length>
#SLOPFINITY_BG_POSITION=center
#SLOPFINITY_BG_PARALLAX=true            # true = background-attachment:fixed
#
# Cards-overlay treatment:
#SLOPFINITY_BG_BLUR_PX=6                # 0 disables; blur applies to background only
#SLOPFINITY_BG_DIM_PCT=30               # 0..100 — black overlay so card text reads cleanly

# ─── LLM Endpoint Pool ───────────────────────────────────────────────────────
# Slopfinity supports a primary GPU endpoint + optional failover Ollama nodes.
# All real IPs/hostnames go in .env (gitignored). Use this file for the schema.
#
# Primary LLM provider (GPU — LMStudio or any OpenAI-compat server).
#SLOPFINITY_LLM_PRIMARY_URL=http://192.168.1.100:1234/v1
#SLOPFINITY_LLM_PRIMARY_MODEL=your-model-id          # blank = auto-pick first
#
# CPU inference fallback — used by smart-mode when GPU is busy.
# Typically a local llama.cpp server or Ollama on the same machine.
#SLOPFINITY_LLM_CPU_URL=http://localhost:11434/v1
#SLOPFINITY_LLM_CPU_MODEL=                           # blank = auto-pick
#
# Additional Ollama failover nodes (comma-separated, probed in order).
# First node that responds with at least one loaded model wins.
#SLOPFINITY_LLM_FAILOVER_URLS=http://192.168.1.101:11434/v1,http://192.168.1.102:11434/v1
#SLOPFINITY_LLM_FAILOVER_MODELS=                     # blank = auto-pick per node
